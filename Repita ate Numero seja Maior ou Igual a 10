algoritmo "Repita ate Numero seja Maior ou Igual a 10"
// Função :
// Autor :
// Data : 15/06/2026
// Seção de Declarações 
var

   numero : inteiro

inicio

      numero <- 0
      
      Repita
      
            numero <- numero + 1
            Escreval(numero)
      
      Ate numero >= 10


fimalgoritmo
