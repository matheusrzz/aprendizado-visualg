algoritmo "Exercício enquanto faca numero de 0 a 10"
// Função :
// Autor :
// Data : 11/06/2026
// Seção de Declarações 
var

   numero: inteiro

inicio

      Escreval(" Digite um numero: ")
      leia(numero)


      Enquanto ( (numero <0) ou (numero >10) ) Faca

               Escreval("Atenção, você precisa digitar um numero de 0 a 10.")
               Escreval("Digite novamente um número nop intervalo de 0 a 10")
               
               leia(numero)


      
      FimEnquanto
      
      Escreval("Muito bem! o número ", numero, " está no intervalo de 0 a 10")


fimalgoritmo
