// Seção de Declarações 
var
   nome : caractere
   minutos : real
   totalpagar: real
   minutosconvertido : real
   horas : real

inicio


      Escreval ("Digite o nome do cliente:")
      leia (nome)
      
      Escreval ("Digite quantos minutos o cliente utilizou")
